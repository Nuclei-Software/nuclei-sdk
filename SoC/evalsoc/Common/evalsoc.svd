          <name>mem_crc_x23_lo</name>
          <description>Write value to this reg lower word to calculate CRC for crc x23.</description>
          <addressOffset>0x308</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
