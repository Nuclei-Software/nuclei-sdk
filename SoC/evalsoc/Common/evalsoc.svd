              <bitOffset>0</bitOffset>
              <bitWidth>64</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <name>mtimecmp5</name>
          <description>M-mode timer compare register for Hart 5.</description>
          <addressOffset>0x5028</addressOffset>
          <size>64</size>
          <access>read-write</access>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>mtimecmp</name>
              <description>Timer compare value for Hart 5. When mtime &gt;= mtimecmp, timer interrupt is generated.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>64</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <name>mtimecmp6</name>
          <description>M-mode timer compare register for Hart 6.</description>
          <addressOffset>0x5030</addressOffset>
          <size>64</size>
          <access>read-write</access>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>mtimecmp</name>
              <description>Timer compare value for Hart 6. When mtime &gt;= mtimecmp, timer interrupt is generated.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>64</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <name>mtimecmp7</name>
          <description>M-mode timer compare register for Hart 7.</description>
          <addressOffset>0x5038</addressOffset>
          <size>64</size>
          <access>read-write</access>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>mtimecmp</name>
              <description>Timer compare value for Hart 7. When mtime &gt;= mtimecmp, timer interrupt is generated.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>64</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <name>mtime</name>
          <description>MTIME register in CLINT mode.</description>
          <addressOffset>0xCFF8</addressOffset>
          <size>64</size>
          <access>read-write</access>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>mtime</name>
              <description>64-bit timer counter value.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>64</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <name>setssip0</name>
          <description>Set Supervisor Software Interrupt request for Hart 0.</description>
          <addressOffset>0xD000</addressOffset>
          <size>32</size>
          <access>write-only</access>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>SETSSIP</name>
              <description>Write 1 to trigger edge Supervisor Software Interrupt for Hart 0, read returns 0.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
              <access>write-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>setssip1</name>
          <description>Set Supervisor Software Interrupt request for Hart 1.</description>
          <addressOffset>0xD004</addressOffset>
          <size>32</size>
          <access>write-only</access>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>SETSSIP</name>
              <description>Write 1 to trigger edge Supervisor Software Interrupt for Hart 1, read returns 0.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
              <access>write-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>setssip2</name>
          <description>Set Supervisor Software Interrupt request for Hart 2.</description>
          <addressOffset>0xD008</addressOffset>
          <size>32</size>
          <access>write-only</access>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>SETSSIP</name>
              <description>Write 1 to trigger edge Supervisor Software Interrupt for Hart 2, read returns 0.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
              <access>write-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>setssip3</name>
          <description>Set Supervisor Software Interrupt request for Hart 3.</description>
          <addressOffset>0xD00C</addressOffset>
          <size>32</size>
          <access>write-only</access>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>SETSSIP</name>
              <description>Write 1 to trigger edge Supervisor Software Interrupt for Hart 3, read returns 0.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
              <access>write-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>setssip4</name>
          <description>Set Supervisor Software Interrupt request for Hart 4.</description>
          <addressOffset>0xD010</addressOffset>
          <size>32</size>
          <access>write-only</access>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>SETSSIP</name>
              <description>Write 1 to trigger edge Supervisor Software Interrupt for Hart 4, read returns 0.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
              <access>write-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>setssip5</name>
          <description>Set Supervisor Software Interrupt request for Hart 5.</description>
          <addressOffset>0xD014</addressOffset>
          <size>32</size>
          <access>write-only</access>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>SETSSIP</name>
              <description>Write 1 to trigger edge Supervisor Software Interrupt for Hart 5, read returns 0.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
              <access>write-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>setssip6</name>
          <description>Set Supervisor Software Interrupt request for Hart 6.</description>
          <addressOffset>0xD018</addressOffset>
          <size>32</size>
          <access>write-only</access>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>SETSSIP</name>
              <description>Write 1 to trigger edge Supervisor Software Interrupt for Hart 6, read returns 0.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
              <access>write-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>setssip7</name>
          <description>Set Supervisor Software Interrupt request for Hart 7.</description>
          <addressOffset>0xD01C</addressOffset>
          <size>32</size>
          <access>write-only</access>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>SETSSIP</name>
              <description>Write 1 to trigger edge Supervisor Software Interrupt for Hart 7, read returns 0.</description>
