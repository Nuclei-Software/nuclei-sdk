        <register>
          <name>pfl1dctrl1</name>
          <description>Controls L1 D-Cache prefetch functions.</description>
          <addressOffset>0x100</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>Reserved</name>
              <description>Reserved 0</description>
              <bitOffset>15</bitOffset>
              <bitWidth>17</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>pref_conflict_decr_sel</name>
              <description>decrease the conflict counter when a number of prefetch is sent. This field select how the number of prefetch:&lt;br&gt;0: disable&lt;br&gt;1: 1024 prefetches&lt;br&gt;2: 512 prefetches&lt;br&gt;3: 256&lt;br&gt;4: 128&lt;br&gt;5: 64&lt;br&gt;6: 32&lt;br&gt;7: 16</description>
              <bitOffset>12</bitOffset>
              <bitWidth>3</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>pref_conflict_stop_th</name>
              <description>when prefetch has Dcache hit, a counter is increased. When the counter is greater than this threshold, the prefetch is stopped</description>
              <bitOffset>8</bitOffset>
              <bitWidth>4</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>pl2_enable</name>
              <description>Enable PL2 prefetching. 0: Disable, 1: Enable</description>
              <bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>pref_mmu_next_cacheline</name>
              <description>When a table walk access for a miss occurs in the MMU, prefetch the next cacheline that is incremented. 0: Disable, 1: Enable</description>
              <bitOffset>6</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>cross_page_pref_ena</name>
              <description>Prefetch cross page enable. 0: Disable, 1: Enable</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>write_pref_ena</name>
              <description>Store prefetch enable. 0: Disable, 1: Enable</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>vector_ena</name>
              <description>Vector pipeline prefetch enable. 0: Disable, 1: Enable</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>scalar_ena</name>
              <description>Scalar pipeline prefetch enable. 0: Disable, 1: Enable</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>cc_ena</name>
              <description>Cluster Cache prefetch enable. 0: Disable, 1: Enable</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>l1d_ena</name>
              <description>L1 D-Cache prefetch enable. 0: Disable, 1: Enable</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <name>pfl1dctrl2</name>
          <description>Controls prefetch degree and write streaming thresholds.</description>
          <addressOffset>0x104</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>Reserved</name>
              <description>Reserved 0</description>
              <bitOffset>20</bitOffset>
              <bitWidth>12</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>write_no_allocate_L2_threshold</name>
              <description>Write streaming no-L2-allocate threshold. The possible values are:&lt;br&gt;0b00 16th consecutive streaming cache line does not allocate in the L2 cache. This is the reset value.&lt;br&gt;0b01 128th consecutive streaming cache line does not allocate in the L2 cache.&lt;br&gt;0b10 512th consecutive streaming cache line does not allocate in the L2 cache.&lt;br&gt;0b11 Disables streaming. All write-allocate lines allocate in the L2 cache.</description>
              <bitOffset>18</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>write_no_allocate_L1_threshold</name>
              <description>Write streaming no-L1-allocate threshold. The possible values are:&lt;br&gt;0b00 4th consecutive streaming cache line does not allocate in the L1 cache. This is the reset value.&lt;br&gt;0b01 64th consecutive streaming cache line does not allocate in the L1 cache.&lt;br&gt;0b10 128th consecutive streaming cache line does not allocate in the L1 cache.&lt;br&gt;0b11 Disables streaming. All write-allocate lines allocate in the L1 cache.</description>
              <bitOffset>16</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>next_line_ena_threshold</name>
              <description>Threshold of enabling next-line mode prefetch. The next line prefetch mode is enabled when the proportion of Dcache miss commands to all commands is less than threshold/16.</description>
              <bitOffset>12</bitOffset>
              <bitWidth>4</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>degree_decr_threshold</name>
              <description>Prefetch degree threshold of decreasing. When the accuracy of a certain prefetch is less than the threshold, the prefetch degree is decreased.</description>
              <bitOffset>6</bitOffset>
              <bitWidth>6</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>degree_incr_threshold</name>
              <description>Prefetch degree threshold of increasing. When the accuracy of a certain prefetch is greater than the threshold, the prefetch degree is increased.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>6</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <name>mergel1dctrl</name>
          <description>Controls write streaming and non-cacheable merge related features.</description>
          <addressOffset>0x108</addressOffset>
