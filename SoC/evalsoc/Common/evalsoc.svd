    <peripheral>
      <name>CIDU</name>
      <description>Address space of CIDU unit. The Cluster Interrupt Distribution Unit (CIDU) is used to distribute external interrupts to the core&apos;s ECLIC, also provides Inter Core Interrupt (ICI) and Semaphores Mechanism.</description>
      <groupName>IREGION</groupName>
      <baseAddress>0x18050000</baseAddress>
      <registers>
        <register>
          <dim>8</dim>
          <dimIncrement>0x4</dimIncrement>
          <name>CORE%s_INT_STATUS</name>
          <description>Core[i] Inter Core Interrupt status register.</description>
          <addressOffset>0x0</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>CORE{index}_INT_STATUS</name>
              <description>Inter core interrupt status register of core i. Each bit can be cleared by writing 1.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <dim>8</dim>
          <dimIncrement>0x4</dimIncrement>
          <name>SEMAPHORE%s</name>
          <description>Semaphore[i] Inter Core Interrupt Semaphore register. Useful for multi-core cluster without SMP enable.</description>
          <addressOffset>0x80</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>CORE_STATUS</name>
              <description>Reset value is 0xf, other value means the specific core owns the semaphore.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>4</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>CLUSTER_STATUS</name>
              <description>Reset value is 0x3f, other value means the specific cluster owns the semaphore.</description>
              <bitOffset>4</bitOffset>
              <bitWidth>6</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>Reserved</name>
              <description>Reserved.</description>
              <bitOffset>10</bitOffset>
              <bitWidth>22</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>ICI_SHADOW_REG</name>
          <description>ICI Interrupt source core ID and target core ID. Write Only register.</description>
          <addressOffset>0x3FFC</addressOffset>
          <size>32</size>
          <access>write-only</access>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>REV_CORE_ID</name>
              <description>The Core ID which receives this Inter Core Interrupt</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
              <access>write-only</access>
            </field>
            <field>
              <name>SEND_CORE_ID</name>
              <description>The Core ID which sends this Inter Core Interrupt</description>
              <bitOffset>16</bitOffset>
              <bitWidth>16</bitWidth>
              <access>write-only</access>
            </field>
          </fields>
        </register>
        <register>
          <dim>8</dim>
          <dimIncrement>0x4</dimIncrement>
          <name>INT%s_INDICATOR</name>
          <description>Indicate interrupt i can be received by which cores.</description>
          <addressOffset>0x4000</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>INT{index}_INDICATOR</name>
              <description>Each bit indicates the core can receive this interrupt or not. 1 means yes, 0 means no.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <dim>8</dim>
          <dimIncrement>0x4</dimIncrement>
          <name>INT%s_MASK</name>
          <description>Mask the INT[i] to the cores or not when the INT[i] Indicator is on.</description>
          <addressOffset>0x8000</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>INT{index}_MASK</name>
              <description>Each bit indicates it should mask the indicator bit or not. 1 means no, 0 means yes. Can only be written when its value is all 1 or be written as all 1.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <name>CORE_NUM</name>
          <description>Indicate the static configuration core num in the cluster.</description>
          <addressOffset>0xC084</addressOffset>
          <size>32</size>
          <access>read-only</access>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>CORE_NUM</name>
              <description>Static configuration core num in the cluster.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>INT_NUM</name>
          <description>Indicate the static configuration interrupt number.</description>
          <addressOffset>0xC090</addressOffset>
          <size>32</size>
          <access>read-only</access>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>INT_NUM</name>
              <description>Static configuration interrupt number.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>CIDU_SRW_CTRL</name>
          <description>Control S-mode can access this CIDU register or not. Only accessible by M-mode.</description>
          <addressOffset>0xC09C</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>Reserved</name>
              <description>Reserved to 0.</description>
              <bitOffset>1</bitOffset>
              <bitWidth>31</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>SRW</name>
              <description>Control S-mode can read or write CIDU registers or not.&lt;br&gt;0: S-Mode can read/write all CIDU registers.&lt;br&gt;1: S-Mode can not read/write CIDU registers</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
      </registers>
    </peripheral>
