<?xml version="1.0" encoding="utf-8"?>
<device schemaVersion="1.1" xmlns:xs="http://www.w3.org/2001/XMLSchema-instance" xs:noNamespaceSchemaLocation="CMSIS-SVD_Schema_1_0.xsd" >
  <vendor>Nuclei</vendor>
  <vendorID>Nuclei</vendorID>
  <name>evalsoc</name>
  <series>Nuclei Evaluation SoC</series>
  <version></version>
  <description>Nuclei Evaluation SoC using Nuclei N/NX Core
  </description>

  <addressUnitBits>8</addressUnitBits>
  <width>32</width>
  <size>32</size>
  <resetValue>0x00000000</resetValue>
  <resetMask>0xFFFFFFFF</resetMask>

  <cpu>
    <name>Evalsoc</name>
    <endian>little</endian>
  </cpu>

  <peripherals>

    <peripheral>
      <name>IINFO</name>
      <description>Some internal information is defined here by memory map registers. IINFO shows internal peripherals configurations or controls some micro-architecture functions.</description>
      <groupName>IREGION</groupName>
      <baseAddress>0x18000000</baseAddress>
      <registers>
        <register>
          <name>mpasize</name>
          <description>Physical Size register. Shows the physical address size supported by the hardware.</description>
          <addressOffset>0x0</addressOffset>
          <size>32</size>
          <access>read-only</access>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>PA_SIZE</name>
              <description>Physical Size. If the PA_SIZE is 48, the number of this register is 48.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>cmo_info</name>
          <description>Shows Nuclei series RISC-V Standard CMO implementation information.</description>
          <addressOffset>0x4</addressOffset>
          <size>32</size>
          <access>read-only</access>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>Reserved</name>
              <description>Reserved 0</description>
              <bitOffset>10</bitOffset>
              <bitWidth>22</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>cbozero_size</name>
              <description>The size of the cache block for cbo.zero instructions.&lt;br&gt;0: 4 bytes&lt;br&gt;1: 8 bytes&lt;br&gt;2: 16 bytes&lt;br&gt;3: 32 bytes&lt;br&gt;4: 64 bytes&lt;br&gt;5: 128 bytes&lt;br&gt;6: 256 bytes&lt;br&gt;7: 512 bytes</description>
              <bitOffset>6</bitOffset>
              <bitWidth>4</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>cmo_size</name>
              <description>The size of the cache block for management and prefetch instructions.&lt;br&gt;0: 4 bytes&lt;br&gt;1: 8 bytes&lt;br&gt;2: 16 bytes&lt;br&gt;3: 32 bytes&lt;br&gt;4: 64 bytes&lt;br&gt;5: 128 bytes&lt;br&gt;6: 256 bytes&lt;br&gt;7: 512 bytes&lt;br&gt;Currently in Nuclei series core, the size is same with D-Cache cacheline.</description>
              <bitOffset>2</bitOffset>
              <bitWidth>4</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>cmo_pft</name>
              <description>Global configuration for CMO Extension&apos;s prefetch support:&lt;br&gt;0: No CMO Extension&apos;s prefetch support, the prefetch.0/prefetch.r/prefetch.w are all implemented as nop.&lt;br&gt;1: Has CMO Extension&apos;s prefetch support.</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>cmo_cfg</name>
              <description>Global configuration for CMO Extension support:&lt;br&gt;0: No CMO Extension support.&lt;br&gt;1: Has CMO Extension support.&lt;br&gt;Currently in Nuclei series core, if there is D-Cache or I-Cache, then it has CMO support.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>sec_base_addr_lo</name>
          <description>Shows the external security controller lower 32-bit base address information.</description>
          <addressOffset>0x8</addressOffset>
          <size>32</size>
          <access>read-only</access>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>sec_base_addr_lo</name>
              <description>Security controller base address low.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>sec_base_addr_hi</name>
          <description>Shows the external security controller higher 32-bit base address information.</description>
          <addressOffset>0xC</addressOffset>
          <size>32</size>
          <access>read-only</access>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>sec_base_addr_hi</name>
              <description>Security controller base address high.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>sec_cfg_info</name>
          <description>Shows the security feature supported by CPU.</description>
          <addressOffset>0x10</addressOffset>
          <size>32</size>
          <access>read-only</access>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>BBOX_NUM</name>
              <description>The value of this field represents the number of black box debugging entries:&lt;br&gt;* 0: indicates that the current core does not support the black box debugging feature.&lt;br&gt;* Non-zero: indicates that the current core supports the black box debugging feature.</description>
              <bitOffset>27</bitOffset>
              <bitWidth>5</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>MPU_NUM</name>
              <description>The value of this field represents the number of mpu entries:&lt;br&gt;* 0: indicates that the current core does not support the mpu feature.&lt;br&gt;* Non-zero: indicates that the current core supports the mpu feature.</description>
              <bitOffset>22</bitOffset>
              <bitWidth>5</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>Reserved</name>
              <description>Reserved</description>
              <bitOffset>18</bitOffset>
              <bitWidth>4</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>PARITY_MODE</name>
              <description>Parity mode, only active when parity_protection enable.&lt;br&gt;* 0: 1-bit parity check mode&lt;br&gt;* 1: 4-bit parity check mode.</description>
              <bitOffset>17</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>BJP_RANDOM_FLUSH</name>
              <description>BJP instruction can send random flush feature support:&lt;br&gt;* 0: Not support&lt;br&gt;* 1: Support</description>
              <bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>STACK_CHECK</name>
              <description>Stack check feature support:&lt;br&gt;* 0: Not support&lt;br&gt;* 1: Support</description>
              <bitOffset>15</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>POWER_DISTURB</name>
              <description>Power scrambling feature support.&lt;br&gt;* 0: Not support&lt;br&gt;* 1: Support</description>
              <bitOffset>14</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>RANDOM_INS_INSERT</name>
              <description>Random instruction insert feature support.&lt;br&gt;* 0: Not support&lt;br&gt;* 1: Support</description>
              <bitOffset>13</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>DATA_POLARITY</name>
              <description>Data polarity feature support.&lt;br&gt;* 0: Not support&lt;br&gt;* 1: Support</description>
              <bitOffset>12</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>KEY_STATE_CLEAR</name>
              <description>Key state clear feature support.&lt;br&gt;* 0: Not support&lt;br&gt;* 1: Support</description>
              <bitOffset>11</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>EXE_MONITOR</name>
              <description>Execution monitor feature support.&lt;br&gt;* 0: Not support&lt;br&gt;* 1: Support, Core will output some internal signal.</description>
              <bitOffset>10</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>SEC_MON_BUS</name>
              <description>Security monitor bus feature support:&lt;br&gt;* 0: Not support&lt;br&gt;* 1: Support, Core will output some error information on this bus.</description>
              <bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>CACHE_FROZE</name>
              <description>Cache Frozen feature support:&lt;br&gt;* 0: Not support&lt;br&gt;* 1: Support, cache miss will not refill data into cache to protect the secure and critical code.</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>CCT</name>
              <description>Instruction execution time consistency feature support:&lt;br&gt;* 0: Not support&lt;br&gt;* 1: Support</description>
              <bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>PPI_LOCK</name>
              <description>PPI Lock feature support:&lt;br&gt;* 0: Not support&lt;br&gt;* 1: Support</description>
              <bitOffset>6</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>TRWB</name>
              <description>Garbage register write-back feature support:&lt;br&gt;* 0: Not support&lt;br&gt;* 1: Support</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>PARITY_PROTECTION</name>
              <description>Register parity protection feature support:&lt;br&gt;* 0: Not support&lt;br&gt;* 1: Support</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>REMAP</name>
              <description>Vector table remap feature support:&lt;br&gt;* 0: Not support&lt;br&gt;* 1: Support</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>ARCG</name>
              <description>Architecture random clock gate feature support:&lt;br&gt;* 0: Not support&lt;br&gt;* 1: Support</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>SEC_DEBUG</name>
              <description>Secure debug feature support:&lt;br&gt;* 0: Not support&lt;br&gt;* 1: Support</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>SECURITY</name>
              <description>Security feature support:&lt;br&gt;* 0: Not support&lt;br&gt;* 1: Support</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>mvlm_cfg_lo</name>
          <description>Shows the VLM configurations information (lower 32 bits).</description>
          <addressOffset>0x24</addressOffset>
          <size>32</size>
          <access>read-only</access>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>vlm_base_lo</name>
              <description>VLM base address [31:10]</description>
              <bitOffset>10</bitOffset>
              <bitWidth>22</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>Reserved</name>
              <description>Reserved 0</description>
              <bitOffset>6</bitOffset>
              <bitWidth>4</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>vlm_size</name>
              <description>0: 0 bytes&lt;br&gt;1: 1K bytes&lt;br&gt;2: 2K bytes&lt;br&gt;3: 4K bytes&lt;br&gt;4: 8K bytes&lt;br&gt;5: 16K bytes&lt;br&gt;6: 32K bytes&lt;br&gt;7: 64K bytes&lt;br&gt;8: 128K bytes&lt;br&gt;9: 256K bytes&lt;br&gt;10: 512K bytes&lt;br&gt;11: 1M bytes&lt;br&gt;12: 2M bytes&lt;br&gt;13: 4M bytes&lt;br&gt;14: 8M bytes&lt;br&gt;15: 16M bytes&lt;br&gt;16: 32M bytes&lt;br&gt;17: 64M bytes&lt;br&gt;18: 128M bytes&lt;br&gt;19: 256M bytes&lt;br&gt;20: 512M bytes&lt;br&gt;21: 1G bytes&lt;br&gt;22: 2G bytes&lt;br&gt;23: 4G bytes&lt;br&gt;others: reserved</description>
              <bitOffset>1</bitOffset>
              <bitWidth>5</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>vlm</name>
              <description>Shows the hardware has VLM configuration or not. 0 means no, 1 means yes.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>mvlm_cfg_hi</name>
          <description>Shows the higher 32 bit of VLM base address.</description>
          <addressOffset>0x28</addressOffset>
          <size>32</size>
          <access>read-only</access>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>vlm_base_hi</name>
              <description>VLM base address high.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>flash_base_addr_lo</name>
          <description>Shows the flash bus configurations information (lower 32 bits).</description>
          <addressOffset>0x2C</addressOffset>
          <size>32</size>
          <access>read-only</access>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>flash_base_lo</name>
              <description>flash bus base address [31:10]</description>
              <bitOffset>10</bitOffset>
              <bitWidth>22</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>Reserved</name>
              <description>Reserved 0</description>
              <bitOffset>6</bitOffset>
              <bitWidth>4</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>flash_size</name>
              <description>0: 0 bytes&lt;br&gt;1: 1K bytes&lt;br&gt;2: 2K bytes&lt;br&gt;3: 4K bytes&lt;br&gt;4: 8K bytes&lt;br&gt;5: 16K bytes&lt;br&gt;6: 32K bytes&lt;br&gt;7: 64K bytes&lt;br&gt;8: 128K bytes&lt;br&gt;9: 256K bytes&lt;br&gt;10: 512K bytes&lt;br&gt;11: 1M bytes&lt;br&gt;12: 2M bytes&lt;br&gt;13: 4M bytes&lt;br&gt;14: 8M bytes&lt;br&gt;15: 16M bytes&lt;br&gt;16: 32M bytes&lt;br&gt;17: 64M bytes&lt;br&gt;18: 128M bytes&lt;br&gt;19: 256M bytes&lt;br&gt;20: 512M bytes&lt;br&gt;21: 1G bytes&lt;br&gt;22: 2G bytes&lt;br&gt;23: 4G bytes&lt;br&gt;others: reserved</description>
              <bitOffset>1</bitOffset>
              <bitWidth>5</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>flash</name>
              <description>Shows the hardware has flash bus configuration or not.&lt;br&gt;0: means no&lt;br&gt;1: means yes.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>flash_base_addr_hi</name>
          <description>Shows the higher 32 bit of flash bus base address.</description>
          <addressOffset>0x30</addressOffset>
          <size>32</size>
          <access>read-only</access>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>flash_base_hi</name>
              <description>Flash bus information</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>vpu_cfg_info</name>
          <description>Shows the VPU configurations information.</description>
          <addressOffset>0x50</addressOffset>
          <size>32</size>
          <access>read-only</access>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>Reserved</name>
              <description>Reserved 0</description>
              <bitOffset>2</bitOffset>
              <bitWidth>30</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>elen64</name>
              <description>1: Support elen=64 when configure VPU&lt;br&gt;0: No support elen=64 when configure VPU</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>nosegnoshuf</name>
              <description>1: No segment and no shuf feature when configure VPU&lt;br&gt;0: Support segment and shuf feature when configure VPU</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>mem_region0_cfg_lo</name>
          <description>Hardware memory-region0 information (lower 32 bits).</description>
          <addressOffset>0x54</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>mem_regionx_base_lo</name>
              <description>mem_regionx&apos;s low 32 bits base address(aligned 1k)</description>
              <bitOffset>10</bitOffset>
              <bitWidth>22</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>mem_regionx_ena</name>
              <description>0: disable&lt;br&gt;1: enable</description>
              <bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>Reserved</name>
              <description>reserved</description>
              <bitOffset>6</bitOffset>
              <bitWidth>3</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>mem_regionx_size</name>
              <description>0: 0 bytes&lt;br&gt;1: 1K bytes&lt;br&gt;2: 2K bytes&lt;br&gt;3: 4K bytes&lt;br&gt;4: 8K bytes&lt;br&gt;5: 16K bytes&lt;br&gt;6: 32K bytes&lt;br&gt;7: 64K bytes&lt;br&gt;8: 128K bytes&lt;br&gt;9: 256K bytes&lt;br&gt;10: 512K bytes&lt;br&gt;11: 1M bytes&lt;br&gt;12: 2M bytes&lt;br&gt;13: 4M bytes&lt;br&gt;14: 8M bytes&lt;br&gt;15: 16M bytes&lt;br&gt;16: 32M bytes&lt;br&gt;17: 64M bytes&lt;br&gt;18: 128M bytes&lt;br&gt;19: 256M bytes&lt;br&gt;20: 512M bytes&lt;br&gt;21: 1G bytes&lt;br&gt;22: 2G bytes&lt;br&gt;23: 4G bytes&lt;br&gt;others: reserved</description>
              <bitOffset>1</bitOffset>
              <bitWidth>5</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>mem_regionx</name>
              <description>0: don&apos;t support mem_regionx&lt;br&gt;1: support mem_regionx</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>mem_region0_cfg_hi</name>
          <description>Hardware memory-region0 information (higher 32 bits).</description>
          <addressOffset>0x58</addressOffset>
          <size>32</size>
          <access>read-only</access>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>mem_regionx_base_hi</name>
              <description>mem_regionx&apos;s high 32 bits base address</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>mem_region1_cfg_lo</name>
          <description>Hardware memory-region1 information (lower 32 bits).</description>
          <addressOffset>0x5C</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>mem_regionx_base_lo</name>
              <description>mem_regionx&apos;s low 32 bits base address(aligned 1k)</description>
              <bitOffset>10</bitOffset>
              <bitWidth>22</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>mem_regionx_ena</name>
              <description>0: disable&lt;br&gt;1: enable</description>
              <bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>Reserved</name>
              <description>reserved</description>
              <bitOffset>6</bitOffset>
              <bitWidth>3</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>mem_regionx_size</name>
              <description>0: 0 bytes&lt;br&gt;1: 1K bytes&lt;br&gt;2: 2K bytes&lt;br&gt;3: 4K bytes&lt;br&gt;4: 8K bytes&lt;br&gt;5: 16K bytes&lt;br&gt;6: 32K bytes&lt;br&gt;7: 64K bytes&lt;br&gt;8: 128K bytes&lt;br&gt;9: 256K bytes&lt;br&gt;10: 512K bytes&lt;br&gt;11: 1M bytes&lt;br&gt;12: 2M bytes&lt;br&gt;13: 4M bytes&lt;br&gt;14: 8M bytes&lt;br&gt;15: 16M bytes&lt;br&gt;16: 32M bytes&lt;br&gt;17: 64M bytes&lt;br&gt;18: 128M bytes&lt;br&gt;19: 256M bytes&lt;br&gt;20: 512M bytes&lt;br&gt;21: 1G bytes&lt;br&gt;22: 2G bytes&lt;br&gt;23: 4G bytes&lt;br&gt;others: reserved</description>
              <bitOffset>1</bitOffset>
              <bitWidth>5</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>mem_regionx</name>
              <description>0: don&apos;t support mem_regionx&lt;br&gt;1: support mem_regionx</description>
              <bitOffset>0</bitOffset>
