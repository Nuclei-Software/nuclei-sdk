              <bitWidth>32</bitWidth>
              <access>write-only</access>
            </field>
          </fields>
        </register>
      </registers>
    </peripheral>
    <peripheral>
      <name>SMP</name>
      <description>Address space of SMP and Cluster Cache. Nuclei Processor Core can optionally support Cluster Cache (CC) and Symmetric Multi-Processor (SMP).</description>
      <groupName>IREGION</groupName>
      <baseAddress>0x18040000</baseAddress>
      <registers>
        <register>
          <name>SMP_VER</name>
          <description>Machine Mode SMP Version Register. Shows the microarchitecture implementation version of SMP related module.</description>
          <addressOffset>0x0</addressOffset>
          <size>32</size>
          <access>read-only</access>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>Mic_Ver</name>
              <description>Micro Version Number</description>
              <bitOffset>0</bitOffset>
              <bitWidth>8</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>Min_Ver</name>
              <description>Minor Version Number</description>
              <bitOffset>8</bitOffset>
              <bitWidth>8</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>Maj_Ver</name>
              <description>Major Version Number</description>
              <bitOffset>16</bitOffset>
              <bitWidth>8</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>Reserved</name>
              <description>Reserved 0</description>
              <bitOffset>24</bitOffset>
              <bitWidth>8</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>SMP_CFG</name>
          <description>Machine Mode SMP Configuration Register. Shows the hardware configuration of SMP related design.</description>
          <addressOffset>0x4</addressOffset>
          <size>32</size>
          <access>read-only</access>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>CC_PRESENT</name>
              <description>Cluster Cache present or not. 0: not present; 1: Present</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>SMP_CORE_NUM</name>
              <description>Indicate core number in the cluster, it is fixed value (smp_core_num -1) when the RTL is generated.</description>
              <bitOffset>1</bitOffset>
              <bitWidth>6</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>IOCP_NUM</name>
              <description>The IO Coherency port number in the cluster, it is fixed value when the RTL is generated.</description>
              <bitOffset>7</bitOffset>
              <bitWidth>6</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>PMON_NUM</name>
              <description>The performance monitor number, it is fixed value when the RTL is generated.</description>
              <bitOffset>13</bitOffset>
              <bitWidth>6</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>Reserved</name>
              <description>Reserved 0</description>
              <bitOffset>19</bitOffset>
              <bitWidth>13</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>CC_CFG</name>
          <description>Machine Mode CC Config Register. Shows the hardware configuration of Cluster Cache.</description>
          <addressOffset>0x8</addressOffset>
          <size>32</size>
          <access>read-only</access>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>CC_SET</name>
              <description>Cluster Cache Set Number = 2^(CC_SET)</description>
              <bitOffset>0</bitOffset>
              <bitWidth>4</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>CC_WAY</name>
              <description>Cluster Cache Way Number = (CC_WAY + 1)</description>
              <bitOffset>4</bitOffset>
              <bitWidth>4</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>CC_LSIZE</name>
              <description>Cluster Cache Line Size = 2^(CC_LSIZE + 2)</description>
              <bitOffset>8</bitOffset>
              <bitWidth>3</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>CC_ECC</name>
              <description>Indicate the Cluster Cache supports ECC or not</description>
              <bitOffset>11</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>CC_TCYCLE</name>
              <description>Indicate the L2 Tag sram access cycle - 1. 0: 1-cycle, 1: 2-cycle</description>
              <bitOffset>12</bitOffset>
              <bitWidth>3</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>CC_DCYCLE</name>
              <description>Indicate the L2 Data sram access cycle - 1. 0: 1-cycle, 1: 2-cycle</description>
              <bitOffset>15</bitOffset>
              <bitWidth>3</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>Reserved</name>
              <description>Reserved 0</description>
              <bitOffset>18</bitOffset>
              <bitWidth>14</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>SMP_ENB</name>
          <description>Machine Mode SMP Enable Register. Controls which cores or all IOCP in the cluster can be cache coherency with each other handled by hardware.</description>
          <addressOffset>0xC</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>SMP_Enable</name>
              <description>SMP Enable Bit for clients in the Cluster. Each bit control one client. The low bit is CORE clients, high bit is IOCP clients.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>Reserved</name>
              <description>Reserved 0</description>
              <bitOffset>16</bitOffset>
              <bitWidth>16</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>CC_CTRL</name>
          <description>Machine Mode CC Control Register. Controls Cluster Cache specific functions and gets some status.</description>
          <addressOffset>0x10</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>CC_EN</name>
              <description>CC Enable Bit. 0: Disable, 1: Enable</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>CC_ECC_EN</name>
              <description>CC ECC Enable Bit. 0: Disable, 1: Enable</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>ECC_EXCP_EN</name>
              <description>CC ECC Exception Enable Bit. 0: Disable, 1: Enable</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>LOCK_ECC_CFG</name>
              <description>Lock the CC ECC Configuration Bit. 0: Disable, 1: Enable. If set to 1, previous bits can&apos;t be changed.</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>LOCK_ECC_ERR_INJ</name>
              <description>Lock CC ECC Error Injection Register. 0: Disable, 1: Enable.</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>RECV_ERR_IRQ_EN</name>
              <description>Enable the interrupt when recoverable error count exceeds the threshold. 0: Disable, 1: Enable</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>FATAL_ERR_IRQ_EN</name>
              <description>Enable the interrupt when fatal error count exceeds the threshold. 0: Disable, 1: Enable</description>
              <bitOffset>6</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>BUS_ERR_PEND</name>
              <description>Indicate if there is Bus Error Pending of all type. 0: No Pending, 1: Pending.</description>
              <bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>BUS_ERR_IRQ_EN</name>
              <description>Enable the Bus Error interrupt of CC maintain operation. 0: Disable, 1: Enable</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>SUP_CMD_EN</name>
              <description>Enable S Mode can operate register CC_sCMD and SMP_PMON_SEL. 0: Disable, 1: Enable</description>
              <bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>USE_CMD_EN</name>
              <description>Enable U Mode can operate register CC_uCMD and SMP_PMON_SEL. 0: Disable, 1: Enable</description>
              <bitOffset>10</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>ECC_CHK_EN</name>
              <description>CC ECC Check Enable Bit. 0: Disable, 1: Enable</description>
              <bitOffset>11</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>CLM_ECC_EN</name>
              <description>CLM ECC Enable Bit. 0: Disable, 1: Enable</description>
              <bitOffset>12</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>CLM_EXCP_EN</name>
              <description>CLM ECC Exception Enable Bit. 0: Disable, 1: Enable</description>
              <bitOffset>13</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>CLM_ECC_CHK_EN</name>
              <description>CLM ECC Check Enable Bit. 0: Disable, 1: Enable</description>
              <bitOffset>14</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>PF_SH_CL_EN</name>
              <description>Enable L1 prefetch to snoop and share cacheline from other cores. 0: Disable, 1: Enable</description>
              <bitOffset>15</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>PF_L2_EARLY_EN</name>
              <description>Enable L2 prefetch to initialize external bus read access while lookup the cluster cache. 0: Disable, 1: Enable</description>
              <bitOffset>16</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>PF_BIU_OUTS_EN</name>
              <description>Enable the limit of outstanding L2 Prefetch. 0: Disable, 1: Enable</description>
              <bitOffset>17</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>I_SNOOP_D_EN</name>
              <description>Snoop to dcache for icache refill reads Enable. 0: Disable, 1: Enable (default in smp cores)</description>
              <bitOffset>18</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>IOCC_ERR</name>
              <description>IOCC Has error. 0: No error, 1: Error</description>
              <bitOffset>19</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>EARLY_WR_ERR</name>
              <description>Early write response has error. 0: No error, 1: Error</description>
              <bitOffset>20</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>PF_NO_WB</name>
              <description>Enable L2 prefetch to abort and avoid dirty cacheline write back. 0: Disable, 1: Enable</description>
              <bitOffset>21</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>Reserved</name>
              <description>Reserved 0</description>
              <bitOffset>22</bitOffset>
              <bitWidth>10</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>CC_mCMD</name>
          <description>Machine Mode CC Command and Status. Sets specific maintain command for Cluster Cache and checks the command result in Machine Mode.</description>
          <addressOffset>0x14</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>CMD</name>
              <description>Cluster Cache Maintain Command Code</description>
              <bitOffset>0</bitOffset>
              <bitWidth>5</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>Reserved</name>
              <description>Reserved 0</description>
              <bitOffset>5</bitOffset>
              <bitWidth>18</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>RESC</name>
              <description>Read as Recoverable ECC Error IRQ Pending, write 1 will clear CC_RECV_CNT.</description>
              <bitOffset>23</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>FESC</name>
              <description>Read as Fatal ECC Error IRQ Pending, write 1 will clear CC_FATAL_CNT.</description>
              <bitOffset>24</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>BESC</name>
              <description>Read as BUS_ERR_PEND, write 1 will clear BUS_ERR_PEND.</description>
              <bitOffset>25</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>Result_Code</name>
              <description>Result of the CMD</description>
              <bitOffset>26</bitOffset>
              <bitWidth>5</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>Complete</name>
              <description>Indicate the CMD complete or not. 0: Not Complete, 1: Complete</description>
              <bitOffset>31</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>CC_ERR_INJ</name>
          <description>CC ECC Error Injection Control Register.</description>
          <addressOffset>0x18</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>INJ_DATA</name>
              <description>Inject error to CC Data Ram</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>INJ_TAG</name>
              <description>Inject error to CC Tag Ram</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>INJ_CLM</name>
              <description>Inject error to CLM Ram</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>INJ_MODE</name>
              <description>Indicate the software ecc code inject mode. 0: Direct Write Mode, 1: XOR Write Mode.</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>CS</name>
              <description>Precise injection error control and status. Write 1 to start, automatic cleared when finished.</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>PRCS</name>
              <description>Precise injection error flag.</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
