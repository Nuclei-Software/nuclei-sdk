        <register>
          <name>CC_sCMD</name>
          <description>Supervisor Mode CC Command and Status. Sets specific maintain command for Cluster Cache and checks the command result in Supervisor Mode.</description>
          <addressOffset>0xC0</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
