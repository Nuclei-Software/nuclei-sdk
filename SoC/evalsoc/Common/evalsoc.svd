    <peripheral>
      <name>DEBUG</name>
      <description>Address space of DEBUG unit.</description>
      <groupName>IREGION</groupName>
      <baseAddress>0x18010000</baseAddress>
    </peripheral>
    <peripheral>
      <name>ECLIC</name>
      <description>Enhanced Core Local Interrupt Controller (ECLIC) for fast interrupt handling.</description>
      <groupName>IREGION</groupName>
      <baseAddress>0x18020000</baseAddress>
      <registers>
        <register>
          <name>cliccfg</name>
          <description>Global configuration register for ECLIC.</description>
          <addressOffset>0x0</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>Reserved</name>
              <description>Reserved, ties to 0.</description>
              <bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>nmbits</name>
              <description>Ties to 1, indicates supervisor-level interrupt support.</description>
              <bitOffset>5</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>nlbits</name>
              <description>Specifies the bit-width of level and priority in clicintctl[0].</description>
              <bitOffset>1</bitOffset>
              <bitWidth>4</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>Reserved_1</name>
              <description>Reserved, ties to 1.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>clicinfo</name>
          <description>Global information register for ECLIC.</description>
          <addressOffset>0x4</addressOffset>
          <size>32</size>
          <access>read-only</access>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>Reserved</name>
              <description>Reserved, ties to 0.</description>
              <bitOffset>29</bitOffset>
              <bitWidth>3</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>SHD_NUM</name>
              <description>Shadow register group number for each privilege mode.</description>
              <bitOffset>25</bitOffset>
              <bitWidth>4</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>CLICINTCTLBITS</name>
              <description>Effective bit-width of clicintctl[0].</description>
              <bitOffset>21</bitOffset>
              <bitWidth>4</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>VERSION</name>
              <description>Hardware implementation version number.</description>
              <bitOffset>13</bitOffset>
              <bitWidth>8</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>NUM_INTERRUPT</name>
              <description>Number of interrupt sources supported.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>13</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>mintthresh</name>
          <description>Interrupt threshold level register for M-mode and S-mode.</description>
          <addressOffset>0x8</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>mth</name>
              <description>Interrupt-level threshold for M-mode.</description>
              <bitOffset>24</bitOffset>
              <bitWidth>8</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>Reserved</name>
              <description>Reserved, ties to 0.</description>
              <bitOffset>16</bitOffset>
              <bitWidth>8</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>sth</name>
              <description>Interrupt-level threshold for S-mode.</description>
              <bitOffset>8</bitOffset>
              <bitWidth>8</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>Reserved_1</name>
              <description>Reserved, ties to 0.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>8</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
        </register>
        <register>
          <dim>64</dim>
          <dimIncrement>0x4</dimIncrement>
          <name>clicintip%s</name>
          <description>M-mode interrupt pending flag register for interrupt source i.</description>
          <addressOffset>0x1000</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>Reserved</name>
              <description>Reserved, ties to 0.</description>
              <bitOffset>1</bitOffset>
              <bitWidth>7</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>IP</name>
              <description>Interrupt source pending flag.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <dim>64</dim>
          <dimIncrement>0x4</dimIncrement>
          <name>clicintie%s</name>
          <description>M-mode interrupt enable register for interrupt source i.</description>
          <addressOffset>0x1001</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>Reserved</name>
              <description>Reserved, ties to 0.</description>
              <bitOffset>1</bitOffset>
              <bitWidth>7</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>IE</name>
              <description>Interrupt enable bit.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <dim>64</dim>
          <dimIncrement>0x4</dimIncrement>
          <name>clicintattr%s</name>
          <description>M-mode interrupt attribute register for interrupt source i.</description>
          <addressOffset>0x1002</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>mode</name>
              <description>Privilege mode to take interrupt: 3=M-mode, 1=S-mode. Only 1 or 3 can be written, other values ignored.</description>
              <bitOffset>6</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>Reserved</name>
              <description>Reserved, ties to 0.</description>
              <bitOffset>3</bitOffset>
              <bitWidth>3</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>trig</name>
              <description>Trigger type: 0=level, 1=rising edge, 3=falling edge.</description>
              <bitOffset>1</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>shv</name>
              <description>Vectored mode: 1=vectored, 0=non-vectored.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <dim>64</dim>
          <dimIncrement>0x4</dimIncrement>
          <name>clicintctl%s</name>
          <description>M-mode interrupt control register for interrupt source i. Used to set the level and priority.</description>
          <addressOffset>0x1003</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>reserved</name>
              <description>Reserved, reads as 0. CLICINTCTLBITS is 3 for calculation.</description>
              <bitOffset>3</bitOffset>
              <bitWidth>5</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>level</name>
              <description>Interrupt level. Higher value = higher priority, can preempt lower level interrupts. nlbits 1 is for calculation.</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>priority</name>
              <description>Interrupt priority within the same level. Higher value = higher priority. Unimplemented low bits are tied to 1. nlbits 1 is for calculation.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <name>sintthresh</name>
          <description>Interrupt threshold level register for S-mode. Mirror of mintthresh.sth.</description>
          <addressOffset>0x2008</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>Reserved</name>
              <description>Reserved, ties to 0.</description>
              <bitOffset>16</bitOffset>
              <bitWidth>16</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>sth</name>
              <description>Interrupt-level threshold for S-mode. Mirror of mintthresh.sth.</description>
              <bitOffset>8</bitOffset>
              <bitWidth>8</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>Reserved_1</name>
              <description>Reserved, ties to 0.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>8</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
        </register>
        <register>
          <dim>64</dim>
          <dimIncrement>0x4</dimIncrement>
          <name>clicintip_s%s</name>
          <description>S-mode interrupt pending flag register for interrupt source i. Only accessible for interrupts configured with mode=1.</description>
          <addressOffset>0x3000</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>Reserved</name>
              <description>Reserved, ties to 0.</description>
              <bitOffset>1</bitOffset>
              <bitWidth>7</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>IP</name>
              <description>Interrupt source pending flag.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <dim>64</dim>
          <dimIncrement>0x4</dimIncrement>
          <name>clicintie_s%s</name>
          <description>S-mode interrupt enable register for interrupt source i. Only accessible for interrupts configured with mode=1.</description>
          <addressOffset>0x3001</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>Reserved</name>
              <description>Reserved, ties to 0.</description>
              <bitOffset>1</bitOffset>
              <bitWidth>7</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>IE</name>
              <description>Interrupt enable bit.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <dim>64</dim>
          <dimIncrement>0x4</dimIncrement>
          <name>clicintattr_s%s</name>
          <description>S-mode interrupt attribute register for interrupt source i. Only accessible for interrupts configured with mode=1.</description>
          <addressOffset>0x3002</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>mode</name>
              <description>Privilege mode (read-only in S-mode).</description>
              <bitOffset>6</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>Reserved</name>
              <description>Reserved, ties to 0.</description>
              <bitOffset>3</bitOffset>
              <bitWidth>3</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>trig</name>
              <description>Trigger type (only low 6 bits writable in S-mode).</description>
              <bitOffset>1</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>shv</name>
              <description>Vectored mode.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <dim>64</dim>
          <dimIncrement>0x4</dimIncrement>
          <name>clicintctl_s%s</name>
          <description>S-mode interrupt control register for interrupt source i. Only accessible for interrupts configured with mode=1.</description>
          <addressOffset>0x3003</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>reserved</name>
              <description>Reserved, reads as 0. CLICINTCTLBITS is 3 for calculation.</description>
              <bitOffset>3</bitOffset>
              <bitWidth>5</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>level</name>
              <description>Interrupt level. Higher value = higher priority, can preempt lower level interrupts. nlbits 1 is for calculation.</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>priority</name>
              <description>Interrupt priority within the same level. Higher value = higher priority. Unimplemented low bits are tied to 1. nlbits 1 is for calculation.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
      </registers>
    </peripheral>
    <peripheral>
      <name>TIMER</name>
      <description>Address space of TIMER unit. The Timer Unit (TIMER) is used to generate the Timer Interrupt and Software Interrupt in Nuclei Processor Core.</description>
      <groupName>IREGION</groupName>
      <baseAddress>0x18030000</baseAddress>
      <registers>
        <register>
          <name>mtime_lo</name>
          <description>Reflect the lower 32-bit value of mtime. Shadow copy of MTIME in CLINT mode.</description>
          <addressOffset>0x0</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>mtime_lo</name>
              <description>Lower 32-bit value of mtime.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <name>mtime_hi</name>
          <description>Reflect the upper 32-bit value of mtime. Shadow copy of MTIME in CLINT mode.</description>
          <addressOffset>0x4</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>mtime_hi</name>
              <description>Upper 32-bit value of mtime.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <name>mtimecmp_lo</name>
          <description>Set the lower 32-bit value of mtimecmp. Shadow copy of MTIMECMP for 1st hart in CLINT mode.</description>
          <addressOffset>0x8</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>mtimecmp_lo</name>
              <description>Lower 32-bit value of mtimecmp.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <name>mtimecmp_hi</name>
          <description>Set the upper 32-bit value of mtimecmp. Shadow copy of MTIMECMP for 1st hart in CLINT mode.</description>
          <addressOffset>0xC</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>mtimecmp_hi</name>
              <description>Upper 32-bit value of mtimecmp.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <name>mtime_srw_ctrl</name>
          <description>Control S-mode can access timer registers or not.</description>
          <addressOffset>0xFEC</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>Reserved</name>
              <description>Reserved, ties to 0</description>
              <bitOffset>1</bitOffset>
              <bitWidth>31</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>SRW</name>
              <description>0: S-Mode can read/write timer registers, 1: S-Mode cannot read/write timer registers</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <name>msftrst</name>
          <description>Generate soft-reset request.</description>
          <addressOffset>0xFF0</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>MSFTRST</name>
              <description>Write 0x80000a5f to generate Soft-Reset Request.</description>
              <bitOffset>31</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>Reserved</name>
              <description>Reserved, ties to 0</description>
              <bitOffset>0</bitOffset>
              <bitWidth>31</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>setssip</name>
          <description>Generate the S-mode Software Interrupt for the local hart.</description>
          <addressOffset>0xFF4</addressOffset>
          <size>32</size>
          <access>write-only</access>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>setssip</name>
              <description>Write 1 to trigger edge Supervisor Software Interrupt, read returns 0.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
              <access>write-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>mtimectl</name>
          <description>Control the behaviors of timer counting.</description>
          <addressOffset>0xFF8</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>Reserved</name>
              <description>Reserved, ties to 0</description>
              <bitOffset>5</bitOffset>
              <bitWidth>27</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>MTIME_SRC</name>
              <description>MTIME source select. 0: timer unit mtime, 1: Soc mtime.</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>HDBG</name>
              <description>Halt-on-debug control. When set, stoptime in dcsr halts the timer counter in debug mode.</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>CLKSRC</name>
              <description>1: core_aon_clk, 0: mtime_toggle_a</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>CMPCLREN</name>
              <description>1: mtime cleared to zero after timer interrupt, 0: mtime increments normally</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>TIMESTOP</name>
              <description>1: timer paused, 0: timer increments normally</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <name>msip</name>
          <description>Generate the M-mode Software Interrupt for the local hart.</description>
          <addressOffset>0xFFC</addressOffset>
